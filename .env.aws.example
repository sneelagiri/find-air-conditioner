AWS_REGION=eu-west-1
Aws__AppConfigSecretName=find-air-conditioners/app-config

# Joybuy scraper defaults.
Scraper__Sources__0__Name=Joybuy
Scraper__Sources__0__UrlTemplate=https://www.joybuy.nl/explore/koelende-airconditioner/HXiijHsL
Scraper__Sources__0__ListingSelector=.SearchResult_productList__zcsx2 .sgm_pc.style_UK_product_card__BL9hp.style_vertical__sqgVF
Scraper__Sources__0__LinkSelector=a
Scraper__Sources__0__ImageSelector=img
Scraper__Sources__0__AvailabilitySelector=.style_UK_OutOfStockText__NYUSc.productCartItem
Scraper__Sources__0__UnavailableKeywords__0=out of stock
Scraper__Sources__0__UnavailableKeywords__1=sold out
Scraper__Sources__0__UnavailableKeywords__2=unavailable
Scraper__Sources__0__UnavailableKeywords__3=not available
Scraper__Sources__0__UnavailableKeywords__4=niet beschikbaar
Scraper__Sources__0__UnavailableKeywords__5=niet beschibaar
Scraper__Sources__0__UnavailableKeywords__6=niet op voorraad
Scraper__Sources__0__UnavailableKeywords__7=uitverkocht

Scheduler__Enabled=true
Scheduler__IntervalMinutes=60
Scheduler__Subscriptions__0__MaxPrice=700
Scheduler__Subscriptions__0__NotificationEmail=you@example.com

Notifications__SmtpHost=
Notifications__SmtpPort=587
Notifications__UseSsl=true
Notifications__FromAddress=no-reply@your-domain.example
Notifications__FromName=Find Air Conditioners
